# Copy this file to .env and fill in values. .env is gitignored.

# The path after .net/ is the database name (e.g. ...mongodb.net/notes?... → DB "notes" in Atlas).
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/notes-app?retryWrites=true&w=majority

# Required for the datadog-agent service (docker compose). Get yours from:
# https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=<YOUR_API_KEY>